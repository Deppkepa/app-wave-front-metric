{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "build analyze.exe",
            "type": "shell",
            "command": "gcc",
            "args": [
                "-c",
                "src/logic/analyze/sqlite3.c",
                "-o",
                "sqlite3.o"
            ],
            "group": "build",
            "problemMatcher": ["$gcc"]
        },
        {
            "label": "build cpp files",
            "type": "shell",
            "command": "g++",
            "args": [
                "-c",
                "src/logic/analyze/analyze.cpp",
                "-Ilib/opencv/OpenCV-MinGW-Build/include",
                "-Ilib/cnpy",
                "-o",
                "analyze.o"
            ],
            "group": "build",
            "problemMatcher": ["$gcc"],
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            },
            "dependsOn": ["build analyze.exe"]
        },
        {
            "label": "build cnpy",
            "type": "shell",
            "command": "g++",
            "args": [
                "-c",
                "lib/cnpy/cnpy.cpp",
                "-Ilib/cnpy",
                "-o",
                "cnpy.o"
            ],
            "group": "build",
            "problemMatcher": ["$gcc"]
        },
        {
            "label": "link all",
            "type": "shell",
            "command": "g++",
            "args": [
                "-o",
                "analyze.exe",
                "analyze.o",
                "cnpy.o",
                "sqlite3.o",
                "-Llib/opencv/OpenCV-MinGW-Build/x64/mingw/lib",
                "-l:libopencv_core455.dll.a",
                "-l:libopencv_imgproc455.dll.a",
                "-l:libopencv_imgcodecs455.dll.a",
                "-lz"
            ],
            "group": "build",
            "problemMatcher": ["$gcc"],
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            },
            "dependsOn": ["build cpp files", "build cnpy"]
        },
        {
            "label": "build and run",
            "type": "shell",
            "command": "./analyze.exe",
            "args": ["analysis_jobs/analysis.db"],
            "dependsOn": ["link all"],
            "group": {
                "kind": "test",
                "isDefault": true
            },
            "problemMatcher": []
        }
    ]
}