{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Python: отладка основного приложения",
            "type": "debugpy",
            "request": "launch",
            "program": "main.py",
            "console": "integratedTerminal"
        },
        {
            "name": "C++: отладка analyze.exe",
            "type": "cppdbg",
            "request": "launch",
            "program": "${workspaceFolder}/analyze.exe",
            "args": ["${workspaceFolder}/analysis_jobs/analysis.db"],
            "stopAtEntry": false,
            "cwd": "${workspaceFolder}",
            "environment": [],
            "externalConsole": false,
            "MIMode": "gdb",
            "miDebuggerPath": "C:/msys64/ucrt64/bin/gdb.exe",
            "setupCommands": [
                {
                    "description": "Включить форматирование",
                    "text": "-enable-pretty-printing",
                    "ignoreFailures": true
                }
            ]
        }
    ],
    "compounds": []
}